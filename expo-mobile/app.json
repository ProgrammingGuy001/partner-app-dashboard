{
  "expo": {
    "name": "Modula Partner",
    "slug": "modula-partner",
    "version": "1.0.0",
    "platforms": ["android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "modula-partner",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#fcfbf9",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.modula.partnerapplication",
      "buildNumber": "1",
      "backgroundColor": "#fcfbf9",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "NSLocationWhenInUseUsageDescription": "Your location is recorded for daily attendance.",
        "NSCameraUsageDescription": "Camera is used to capture your attendance photo.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used to attach attendance photos."
      }
    },
    "android": {
      "package": "com.modula.partnerapplication",
      "versionCode": 1,
      "allowBackup": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E6F4FE"
      },
      "backgroundColor": "#fcfbf9"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/6e6ab0e7-9845-49e7-864e-f0680875d1fe"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      "expo-secure-store",
      "expo-location",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a"
            ],
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableBundleCompression": true
          }
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Modula Partner to attach attendance photos.",
          "cameraPermission": "Allow Modula Partner to capture your attendance photo.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6e6ab0e7-9845-49e7-864e-f0680875d1fe"
      }
    },
    "owner": "ayush_modula"
  }
}
