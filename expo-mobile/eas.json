{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://adminapi.modula.in/api/v1",
        "EXPO_PUBLIC_APP_NAME": "Modula Partner (Dev)"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://adminapi.modula.in/api/v1",
        "EXPO_PUBLIC_APP_NAME": "Modula Partner (Preview)"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://adminapi.modula.in/api/v1",
        "EXPO_PUBLIC_APP_NAME": "Modula Partner",
        "EXPO_NO_SOURCEMAPS": "1"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "large"
      },
      "cache": {
        "disabled": false
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    },
    "production-aab": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}